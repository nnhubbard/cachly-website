                 ("10-settings-map.png", "Settings &rsaquo; Map Options &amp; Navigation."),
                 ("11-settings-caches.png", "Settings &rsaquo; Caches &amp; Waypoints &mdash; live search and clustering."),
                 ("12-settings-proximity.png", "Settings &rsaquo; Proximity Alert."),
                 ("08-settings-users.png", "Settings &rsaquo; Users &mdash; the primary account used across Cachly.")],
}

def render_shots(page_id):
    shots = SCREENSHOTS.get(page_id)
    if not shots:
        return ""
    figs = []
    for fname, cap in shots:
        figs.append(
            f'<figure class="shot"><img loading="lazy" src="assets/screenshots/{fname}" '
            f'alt="{esc(cap)}" width="248"><figcaption>{cap}</figcaption></figure>')
    return '<div class="shots">\n' + "\n".join(figs) + '\n</div>\n'

def _slugify(t):
    return re.sub(r"[^a-z0-9]+", "-", (t or "").lower()).strip("-") or "screen"

_ui_path = os.path.join(DOCS, "assets", "ui-reference.json")
UI = json.load(open(_ui_path, encoding="utf-8")) if os.path.exists(_ui_path) else []
BY_AREA = {}
for _s in UI:
    BY_AREA.setdefault(_s["area"], []).append(_s)

# Stable, unique anchor per screen, derived from its title (never the class name).
ANCHOR = {}
_used_anchors = set()
for _s in UI:
    _base = _slugify(_s["title"])
    _a, _i = _base, 2
    while _a in _used_anchors:
        _a = f"{_base}-{_i}"
        _i += 1
    _used_anchors.add(_a)
    ANCHOR[_s["class"]] = _a

def render_screen(s):
    out = ['<div class="screen-ref">']
    out.append(
        f'<h3 class="screen-name" id="{ANCHOR[s["class"]]}">{esc(s["title"])}</h3>')
    sections = [c["label"] for c in s["controls"]
                if c["kind"] == "Section" and c["detail"] == "header"]
    if sections:
        out.append('<p class="screen-sections"><span class="seclabel">Sections:</span> '
                   + " &middot; ".join(esc(x) for x in sections) + '</p>')
    rows = [c for c in s["controls"] if c["kind"] != "Section"]
    if rows:
        MAX_ROWS = 50
        extra = max(0, len(rows) - MAX_ROWS)
        out.append('<table class="control-table"><thead><tr>'
                   '<th>Control</th><th>Label</th><th>What it does</th></tr></thead><tbody>')
        for c in rows[:MAX_ROWS]:
            if c["detail"]:
                does = esc(c["detail"])
            elif c["action"]:
                does = f'<span class="doaction">{esc(c["action"])}</span>'
            else:
                does = ""
            out.append(f'<tr><td><span class="ctrl-kind">{esc(c["kind"])}</span></td>'
                       f'<td>{esc(c["label"])}</td><td>{does}</td></tr>')
        if extra:
            out.append(f'<tr><td></td><td colspan="2" class="screen-empty">'
                       f'+{extra} more control{"s" if extra != 1 else ""}</td></tr>')
        out.append('</tbody></table>')
    elif not sections:
        out.append('<p class="screen-empty">This screen&rsquo;s controls are built in code; '
                   'no labeled controls were found in the interface file.</p>')
    out.append('</div>')
    return "\n".join(out)

def screens_for(area):
    return sorted(BY_AREA.get(area, []), key=lambda s: (s["title"] or s["class"]).lower())

REF_INTRO = (
    '<div class="callout note"><span class="callout-icon" aria-hidden="true">&#128241;</span>'
    '<div class="callout-body">The screens and controls below are generated from Cachly&rsquo;s '
    'interface files, so the labels match what you see in the app. A few controls are created in '
    'code and may not all be listed. The complete catalog is on the '
    '<a href="screen-reference.html">All Screens</a> page.</div></div>')

# Prepend real screenshots to the top of each page that has them.
for p in PAGES:
    sh = render_shots(p["id"])
    if sh:
        p["body"] = sh + "\n" + p["body"]

# Inject a "Screens & controls" section into each feature page that has screens.
for p in PAGES:
    scr = screens_for(p["id"])
    if not scr:
        continue
    blocks = "\n".join(render_screen(s) for s in scr)
    p["body"] = p["body"].rstrip() + (
        f'\n\n        <h2 id="screens">Screens &amp; controls</h2>\n'
        f'        {REF_INTRO}\n{blocks}\n')

# Build the master All-Screens reference page.
_total_ctrls = sum(len(s["controls"]) for s in UI)
_ref_parts = [
    f'<div class="callout note"><span class="callout-icon" aria-hidden="true">&#129513;</span>'
    f'<div class="callout-body">This catalog is generated directly from Cachly&rsquo;s interface '
    f'files: <strong>{len(UI)} screens</strong> and <strong>{_total_ctrls} controls</strong>, grouped '
    f'by area. The &ldquo;What it does&rdquo; column reflects the action each control triggers. '
    f'Controls built entirely in code may not appear.</div></div>']
for area in NAV_ORDER:
    scr = screens_for(area)
    if not scr:
        continue
    title = AREA_TITLES.get(area, area)
    _ref_parts.append(
        f'<h2 id="area-{area}">{esc(title)} '
        f'<span class="ref-area-count">{len(scr)} screen{"s" if len(scr) != 1 else ""}</span></h2>')
    _ref_parts.append(f'<p>Guide: <a href="{area}.html">{esc(title)}</a></p>')
    _ref_parts.extend(render_screen(s) for s in scr)

page("screen-reference", "All Screens",
     "Complete reference of every Cachly screen and its controls, generated from the app's interface files.",
     "All Screens", "All Screens &amp; Controls",
     "Every screen in Cachly and the controls on it &mdash; generated directly from the app&rsquo;s interface files and grouped by area. Use search (&#8984;K) to jump to a screen by name.",
     "\n".join(_ref_parts))

# Search index for screens (written here so anchors match the generated pages).
_search_entries = []
for s in UI:
    labels = [c["label"] for c in s["controls"] if c["label"] and not c["label"].startswith("(")]
    _search_entries.append({
        "title": s["title"], "section": "Screen reference",
        "href": "screen-reference.html#" + ANCHOR[s["class"]],
        "text": ", ".join(dict.fromkeys(labels))[:240],
    })
with open(os.path.join(DOCS, "assets", "ui-search-index.js"), "w", encoding="utf-8") as _f:
    _f.write("/* Auto-generated by _generate.py — do not edit by hand. */\n")
    _f.write("window.CACHLY_UI_INDEX = " + json.dumps(_search_entries, ensure_ascii=False, indent=1) + ";\n")

# ===========================================================================
# Write files
# ===========================================================================

count = 0
for p in PAGES:
    out = os.path.join(DOCS, p["id"] + ".html")
    with open(out, "w", encoding="utf-8") as f:
        f.write(SHELL.format(**p))
    count += 1

print(f"Generated {count} pages in {DOCS}")
for p in PAGES:
    print("  -", p["id"] + ".html")
