            ("40-map-types.png", "The Map Types chooser, with Apple and Google map styles and the offline/other sources.")],
    "geocache-details": [("23-geocache-detail.png", "A geocache detail screen &mdash; description, hint, logs, attributes, waypoints, trackables and corrected coordinates.")],
    "waypoints": [("24-waypoints.png", "A cache&rsquo;s waypoints, with the User/Cache toggle and each waypoint&rsquo;s coordinates.")],
    "lists": [("03-lists.png", "The Lists tab with the Offline/Online toggle and your offline sets."),
